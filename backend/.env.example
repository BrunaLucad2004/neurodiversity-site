# ========= SERVER =========
# Porta em que a API vai rodar localmente
PORT=

# URL do frontend autorizada pelo CORS (evita requisições de origens desconhecidas)
CORS_ORIGIN=

# URL base do frontend (usada para montar links nos e-mails, ex: link de recuperação de senha)
FRONTEND_URL=

# ========= DATABASE =========
# URI de conexão com o MongoDB Atlas (inclui usuário, senha e nome do banco)
MONGO_URI=

# ========= SESSION STORAGE =========
# URL de conexão com o Redis (usado para armazenar as sessões dos usuários)
REDIS_URL=

# ========= SESSION =========
# Chave secreta usada para assinar o cookie de sessão (use uma string longa e aleatória)
SESSION_SECRET=

# Tempo de duração da sessão antes de expirar (ex: 7d, 24h, 3600000)
SESSION_LIFETIME=

# ========= JWT =========
# Chave secreta usada para assinar os tokens JWT (use uma string longa e aleatória)
JWT_SECRET=

# Tempo de validade do token JWT (ex: 1h, 15m)
JWT_EXPIRES_IN=

# ========= MAIL =========
# Endereço do servidor SMTP (ex: smtp.gmail.com)
MAIL_HOST=

# Porta do servidor SMTP (587 para TLS, 465 para SSL)
MAIL_PORT=

# E-mail remetente usado para enviar as mensagens
MAIL_USER=

# Senha ou app password do e-mail remetente
MAIL_PASS=